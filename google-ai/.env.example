# ─── Our control-plane Postgres (provisioned by Vercel's Postgres/Neon integration) ───
DATABASE_URL=

# ─── Vercel integration identity (from the Integrations Console once registered) ───
# Used to verify that inbound partner-API calls (/v1/installations/...) really came from Vercel.
VERCEL_INTEGRATION_CLIENT_ID=
VERCEL_INTEGRATION_CLIENT_SECRET=

# ─── Google Cloud — YOUR project. These are the keys customers resell through. ───
# A single API key works for Gemini (Generative Language API). Vertex/Maps/Search may need
# a service-account JSON instead; add GOOGLE_APPLICATION_CREDENTIALS_JSON when we wire those.
GOOGLE_API_KEY=
GOOGLE_PROJECT_ID=

# ─── This app's public origin (the proxy + SSO + partner-API host) ───
APP_BASE_URL=https://google-ai.vercel.app

# ─── Secret used to sign/verify the scoped API keys we issue to each provisioned resource ───
KEY_SIGNING_SECRET=
