# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Any current Claude model id. Point this at the latest Opus for maximum
# capability, or a Sonnet model for a faster/cheaper default.
MODEL=claude-sonnet-4-6
# Reasoning effort: low | medium | high | xhigh | max
# (xhigh/max are Opus-tier only)
EFFORT=high
MAX_AGENT_STEPS=10
# Optional: override the agent's system prompt
# SYSTEM_PROMPT=You are uni, a specialized assistant for ...

# Supabase (optional — the agent runs statelessly if these are unset)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Server
PORT=3000
