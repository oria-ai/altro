{
  "functions": {
    "api/dream.js": {
      "maxDuration": 120
    },
    "api/admin.js": {
      "maxDuration": 120
    },
    "api/world.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/stones",
      "schedule": "0 6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "admin\\.(shaym\\.beauty|stones\\.art)"
        }
      ],
      "destination": "/admin.html",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(www\\.)?shaym\\.beauty"
        }
      ],
      "destination": "https://stones.art/:path*",
      "permanent": true
    }
  ]
}