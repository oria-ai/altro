# ─── Our control-plane Postgres (Vercel/Neon) ───
DATABASE_URL=

# ─── Vercel integration identity (OAuth interim) ───
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# ─── Cloudflare — YOUR account. These are the creds customers resell through. ───
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── This app's public origin (proxy + SSO + partner-API host) ───
APP_BASE_URL=https://cloudflare-vercel.vercel.app

# ─── Secret used to sign/verify the scoped keys we issue ───
KEY_SIGNING_SECRET=

# ─── Protects the daily billing cron ───
CRON_SECRET=
